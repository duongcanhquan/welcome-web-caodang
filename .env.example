# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Cloudflare R2 (S3-compatible) ────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cay-khoa-2026
# Custom domain gắn bucket (public-read, URL vĩnh viễn)
NEXT_PUBLIC_R2_PUBLIC_URL=https://img.cay.vietmycollege.com

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cay.vietmycollege.com

# ─── Admin (Supabase Auth — email admin) ────────────────────
# Admin đăng nhập qua Supabase Auth; không cần secret riêng.
# Tạo user admin trong Supabase Dashboard → Authentication.
